# Amazon FBA Bot — Environment Variables
# Copy this to .env for local development

# Claude API key (required for listing writer)
ANTHROPIC_API_KEY=sk-ant-...

# Resend email (required for alerts)
RESEND_API_KEY=re_...
FROM_EMAIL=FBA Bot <alerts@yourdomain.com>
ALERT_EMAIL=you@yourdomain.com

# Set to "true" to skip all external API calls (emails, Claude)
DRY_RUN=false

# Railway persistent volume mount path (optional, defaults to ".")
DATA_DIR=/data

# Server port (Railway sets this automatically)
PORT=3000

# Chromium path (set automatically in Dockerfile)
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium
